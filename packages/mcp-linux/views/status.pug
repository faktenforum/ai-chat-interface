extends layout

block styles
  link(rel="stylesheet" href="/css/status.css")

block content
  .container
    .page-header
      .page-header-main
        h1 Account Status
        p.subtitle Overview of your Linux account, workspaces, and active sessions.

    .grid.grid-primary
      .card#userCard
        h2 Account
        .card-body
          p Loading account information...

      .card#workspacesCard
        h2 Workspaces
        .card-body
          p Loading workspaces...

    .grid.grid-secondary
      .card#uploadsCard
        h2 Upload Sessions
        .card-body
          p Loading upload sessions...

      .card#downloadsCard
        h2 Download Links
        .card-body
          p Loading download links...

      .card#terminalsCard
        h2 Terminals
        .card-body
          p Loading terminals...

    .status-banner#statusBanner

block scripts
  script(src="/js/status.js")

