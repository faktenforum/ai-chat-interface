extends layout

block styles
  link(rel="stylesheet" href="/css/status.css")

block content
  .container
    .page-header
      .page-header-main
        h1 Workspace: #{workspaceName}
        p.subtitle Detailed status for this workspace (git status, code index, plan).

    .grid.grid-primary
      .card#workspaceSummaryCard
        h2 Summary
        .card-body
          p Loading workspace summary...

      .card#workspaceCodeIndexCard
        h2 Code index
        .card-body
          p Loading code index status...

    .card#workspacePlanCard
      h2 Plan & Tasks
      .card-body
        p Loading plan and tasks...

    .status-banner#statusBanner

block scripts
  script(src="/js/workspace-status.js")

