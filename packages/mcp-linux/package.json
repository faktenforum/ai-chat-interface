{
  "name": "@ai-chat-interface/mcp-linux",
  "version": "1.0.0",
  "description": "MCP Linux Server - Per-user isolated Linux terminal environments with persistent workspaces",
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "start": "./src/server.ts",
    "dev": "node --watch --experimental-specifier-resolution=node --experimental-strip-types --experimental-transform-types --no-warnings src/server.ts",
    "lint": "eslint . --ext .ts",
    "test:e2e": "node --experimental-specifier-resolution=node --experimental-strip-types --experimental-transform-types --no-warnings test/e2e-document-creator-workspace.ts",
    "check": "npm run check:self && npm run check:frontend",
    "check:self": "tsc --noEmit",
    "check:frontend": "cd frontend && npm run check",
    "build": "npm run build:frontend",
    "build:frontend": "cd frontend && npm install && npm run build"
  },
  "dependencies": {
    "@codebase-indexer/core": "file:../../dev/codebase-indexer/packages/core",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "busboy": "^1.6.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "js-yaml": "^4.1.1",
    "node-pty": "^1.1.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
